{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)",    "destination": "/_/backend/api/$1"    },
    { "source": "/sitemap.xml", "destination": "/_/backend/sitemap.xml" },
    { "source": "/robots.txt",  "destination": "/_/backend/robots.txt"  }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
